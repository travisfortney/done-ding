#!/usr/bin/env bash
set -euo pipefail

sound="${DONE_DING_SOUND:-/System/Library/Sounds/Pop.aiff}"
delay="${DONE_DING_DELAY:-1.5}"
log_file="${DONE_DING_LOG:-/tmp/done-ding.log}"
player="${DONE_DING_PLAYER:-/usr/bin/afplay}"
label="${1:-task}"

{
  printf '[%s] finished: %s\n' "$(date '+%F %T')" "$label" >> "$log_file"
  sleep "$delay"
  "$player" "$sound" >/dev/null 2>&1 || true
} &
